{
  "name": "aural-ui",
  "version": "2.1.21",
  "type": "module",
  "description": "A modern CLI toolkit for seamlessly integrating customizable UI components into React project. Quickly scaffold, add, and manage production-ready components with minimal configuration.",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Pocket-Fm/fm-ui.git"
  },
  "sideEffects": false,
  "main": "dist/index.cjs",
  "bin": {
    "aural-ui": "./dist/index.cjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "validate": "tsx src/core/validation/verify.ts",
    "prebuild": "npm run lint && npm run format && npm run validate",
    "build": "tsup",
    "dev": "tsup --watch",
    "format": "npx prettier --check ./src",
    "format:fix": "npx prettier --write ./src",
    "prepublishOnly": "NODE_ENV=production npm run build",
    "start": "node dist/index.js",
    "test": "jest",
    "version-packages": "changeset version --version",
    "release": "changeset publish",
    "theme-storybook": "tsx -r tsconfig-paths/register src/core/services/theme-storybook.ts",
    "prestorybook": "npm run theme-storybook",
    "storybook": "storybook dev -p 6006",
    "storybook:serve": "storybook dev -p ${PORT:-6006} --host 0.0.0.0 --ci",
    "prebuild-storybook": "tsx src/core/services/theme-storybook.ts || npm run theme-storybook",
    "build-storybook": "storybook build --docs-json",
    "serve-storybook": "node mcp-server.js",
    "deploy-storybook": "netlify deploy --prod --dir=storybook-static",
    "lint": "eslint ./src --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint ./src --ext .ts,.tsx,.js,.jsx --fix",
    "prepare": "husky"
  },
  "keywords": [
    "cli",
    "components",
    "ui",
    "react",
    "tailwind",
    "shadcn",
    "radix-ui",
    "component-library",
    "ui-components",
    "design-system",
    "typescript",
    "theming",
    "react-components"
  ],
  "author": "Sawan Kumar (sawan.kumar@pocketfm.com)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Pocket-Fm/fm-ui/issues"
  },
  "homepage": "https://github.com/Pocket-Fm/fm-ui#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "chalk": "^4.1.2",
    "cli-progress": "^3.12.0",
    "commander": "^9.4.0",
    "figlet": "^1.8.1",
    "fs-extra": "^10.1.0",
    "glob": "^8.0.3",
    "handlebars": "^4.7.7",
    "inquirer": "^8.2.4",
    "ora": "^5.4.1",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.2",
    "@chromatic-com/storybook": "^5.0.1",
    "@hookform/resolvers": "^5.0.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.4.1",
    "@radix-ui/react-accessible-icon": "^1.1.7",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-hover-card": "^1.1.14",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toggle": "^1.1.9",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@storybook/addon-docs": "10.2.10",
    "@storybook/addon-mcp": "^0.2.3",
    "@storybook/addon-vitest": "10.2.10",
    "@storybook/react-vite": "10.2.10",
    "@tailwindcss/vite": "^4.1.4",
    "@types/cli-progress": "^3.11.6",
    "@types/figlet": "^1.7.0",
    "@types/fs-extra": "^9.0.13",
    "@types/glob": "^8.0.0",
    "@types/inquirer": "^8.2.5",
    "@types/node": "^18.11.9",
    "@types/react": "^19.1.2",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "@vitest/browser": "^3.1.3",
    "@vitest/coverage-v8": "^3.1.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.0",
    "eslint-plugin-storybook": "10.2.10",
    "husky": "^9.1.7",
    "playwright": "^1.52.0",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "react-hook-form": "^7.56.4",
    "react-resizable-panels": "^3.0.2",
    "sonner": "^2.0.3",
    "storybook": "10.2.10",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsup": "^8.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.1.3",
    "zod": "^3.25.32"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
