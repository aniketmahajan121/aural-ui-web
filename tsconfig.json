{
  "compilerOptions": {
    "jsx": "react",
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "outDir": "./dist",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "src/*": ["src/*"],
      "@/*": ["src/*"],
      "@components/*": ["src/ui/components/*"],
      "@fonts/*": ["src/ui/fonts/*"],
      "@hooks/*": ["src/ui/hooks/*"],
      "@icons/*": ["src/ui/icons/*"],
      "@lib/*": ["src/ui/lib/*"],
      "@styles/*": ["src/ui/styles/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
